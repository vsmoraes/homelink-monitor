[
  {
    "step_title": "HomeLink Monitor setup",
    "items": [
      {
        "type": "textfield",
        "desc": "Admin username",
        "subitems": [
          {
            "key": "ADMIN_USERNAME",
            "desc": "Username",
            "defaultValue": "admin",
            "validator": {
              "allowBlank": false
            }
          }
        ]
      },
      {
        "type": "password",
        "desc": "Admin password",
        "subitems": [
          {
            "key": "ADMIN_PASSWORD",
            "desc": "Password",
            "validator": {
              "allowBlank": false
            }
          }
        ]
      },
      {
        "type": "password",
        "desc": "Confirm admin password",
        "subitems": [
          {
            "key": "ADMIN_PASSWORD_CONFIRM",
            "desc": "Confirm password",
            "validator": {
              "allowBlank": false,
              "equalTo": "ADMIN_PASSWORD"
            }
          }
        ]
      },
      {
        "type": "textfield",
        "desc": "HTTP port",
        "subitems": [
          {
            "key": "HTTP_PORT",
            "desc": "Port",
            "defaultValue": "8810",
            "validator": {
              "allowBlank": false,
              "regex": "^[0-9]+$",
              "min": 1024,
              "max": 65535
            }
          }
        ]
      },
      {
        "type": "singleselect",
        "desc": "DSM notifications",
        "subitems": [
          {
            "key": "DSM_NOTIFICATIONS_ENABLED",
            "desc": "Enable DSM notifications",
            "defaultValue": "true",
            "values": [
              {
                "key": "true",
                "value": "Enabled"
              },
              {
                "key": "false",
                "value": "Disabled"
              }
            ]
          }
        ]
      }
    ]
  }
]
