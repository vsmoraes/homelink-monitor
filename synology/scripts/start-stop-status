#!/bin/sh
set -eu

PKG_NAME="homelink-monitor"
CONTAINER_NAME="homelink-monitor"
PKG_DEST="${SYNOPKG_PKGDEST:-/var/packages/$PKG_NAME/target}"
PKG_VAR="${SYNOPKG_PKGVAR:-/var/packages/$PKG_NAME/var}"
APP_ENV="$PKG_VAR/config/app.env"
LOG_DIR="$PKG_VAR/logs"
HELPER="$PKG_DEST/notification-helper.sh"
HELPER_PID="$PKG_VAR/notification-helper.pid"

is_running() {
  command -v docker >/dev/null 2>&1 || return 1
  [ "$(docker inspect -f '{{.State.Running}}' "$CONTAINER_NAME" 2>/dev/null || true)" = "true" ]
}

start_helper() {
  [ -f "$APP_ENV" ] || return 0
  notifications_enabled="$(sed -n 's/^DSM_NOTIFICATIONS_ENABLED=//p' "$APP_ENV" | tail -n 1)"
  case "${notifications_enabled:-true}" in
    true|1|yes|on) ;;
    *) return 0 ;;
  esac
  [ -x "$HELPER" ] || return 0
  if [ -f "$HELPER_PID" ] && kill -0 "$(cat "$HELPER_PID")" 2>/dev/null; then
    return 0
  fi
  mkdir -p "$LOG_DIR"
  "$HELPER" >/dev/null 2>&1 &
  echo "$!" > "$HELPER_PID"
}

stop_helper() {
  if [ -f "$HELPER_PID" ]; then
    pid="$(cat "$HELPER_PID" 2>/dev/null || true)"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
    fi
    rm -f "$HELPER_PID"
  fi
}

case "${1:-}" in
  prestart|prestop)
    exit 0
    ;;
  start)
    mkdir -p "$LOG_DIR"
    start_helper
    ;;
  stop)
    stop_helper
    ;;
  status)
    if is_running; then
      exit 0
    fi
    exit 3
    ;;
  log)
    echo "$LOG_DIR/notification-helper.log"
    if command -v docker >/dev/null 2>&1; then
      docker logs --tail 100 "$CONTAINER_NAME" 2>/dev/null || true
    fi
    ;;
  *)
    echo "Usage: $0 {start|stop|status|log}" >&2
    exit 1
    ;;
esac

exit 0
